---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import '../../styles/perfume.css';

const perfumes = await getCollection('perfume');

const sortedPerfumes = perfumes.sort((a, b) =>
  (a.data.brandName || '').localeCompare(b.data.brandName || '')
);
---

<Layout title="Perfumes — Mimya">
  <div class="perfume-page-header">
    <h1>Our <span class="text-gradient">Perfumes</span></h1>
    <p>Discover fragrances curated with top, middle, and base notes.</p>
  </div>

  <div class="perfume-grid">
    {sortedPerfumes.map((perfume) => {
      const slug = perfume.data.slug || perfume.id;
      return (
        <a href={`/perfume/${slug}`} class="perfume-card">
          {perfume.data.imageUrl
            ? <img
                src={perfume.data.imageUrl}
                alt={perfume.data.perfumeName}
                class="perfume-card-image"
                loading="lazy"
              />
            : <div class="perfume-card-image-placeholder">🌸</div>
          }

          <div class="perfume-card-body">
            {perfume.data.brandName && (
              <span class="perfume-card-brand">{perfume.data.brandName}</span>
            )}

            <h2 class="perfume-card-name">{perfume.data.perfumeName}</h2>

            <div class="perfume-card-meta">
              {perfume.data.use && (
                <span class="perfume-badge">{perfume.data.use}</span>
              )}
              {perfume.data.year && (
                <span class="perfume-badge year">{perfume.data.year}</span>
              )}
            </div>

            {perfume.data.openingSentence && (
              <p class="perfume-card-opening">{perfume.data.openingSentence}</p>
            )}

            {(perfume.data.topNotes || perfume.data.middleNotes || perfume.data.baseNotes) && (
              <p class="perfume-card-notes">
                {[perfume.data.topNotes, perfume.data.middleNotes, perfume.data.baseNotes]
                  .filter(Boolean)
                  .join(', ')
                  .split(',')
                  .map((s) => s.trim())
                  .filter(Boolean)
                  .slice(0, 3)
                  .join(', ')}
              </p>
            )}
          </div>
        </a>
      );
    })}
  </div>
</Layout>