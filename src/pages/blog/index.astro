---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const blogs = await getCollection('blogs');

const sortedBlogs = blogs.sort((a, b) => 
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<Layout title="Blog — Mimya">
  <header>
    <h1>Our <span class="text-gradient">Blog</span></h1>
    <p>Explore our latest articles on fragrance, perfumery, and scent science.</p>
  </header>

  <div class="grid">
    {sortedBlogs.map((blog) => {
     
      return (
        <a href={`/blog/${blog.data.slug}`} class="card">
          <div class="card-meta">
            <span class="category-badge">{blog.data.categories}</span>
            <span class="date">{blog.data.date}</span>
          </div>
          <h2>{blog.data.title}</h2>
          <p>{blog.data.excerpt?.substring(0, 130)}...</p>
          <span class="author">By {blog.data.authorFirstName} {blog.data.authorLastName}</span>
        </a>
      );
    })}
  </div>
</Layout>

<style>
  h1 {
    font-size: 3rem;
    font-weight: 900;
    text-align: center;
    margin-bottom: 0.5rem;
  }
  .text-gradient {
    background-image: var(--accent-gradient);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-size: 400%;
    background-position: 0%;
  }
  header {
    text-align: center;
    margin-bottom: 3rem;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .card {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);
    transition: transform 0.2s, box-shadow 0.2s;
    text-decoration: none;
    color: inherit;
  }
  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
  }
  .card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .category-badge {
    background: rgba(var(--accent-light), 0.3);
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    font-size: 0.75rem;
    font-weight: 700;
    color: rgb(var(--accent-dark));
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .date {
    font-size: 0.8rem;
    color: #94a3b8;
    font-weight: 500;
  }
  .card h2 {
    margin: 0;
    font-size: 1.3rem;
    color: #0f172a;
    font-weight: 800;
    line-height: 1.3;
  }
  .card p {
    margin: 0;
    font-size: 0.95rem;
    color: #334155;
  }
  .author {
    font-size: 0.85rem;
    color: #64748b;
    font-weight: 600;
    margin-top: 0.5rem;
  }
</style>