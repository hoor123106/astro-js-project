---
import Layout from '../../layouts/Layout.astro';
import AboutHero from '../../components/AboutHero.astro';
import AboutMission from '../../components/AboutMission.astro';
import AboutInfo from '../../components/AboutInfo.astro';
import AboutTeam from '../../components/AboutTeam.astro';
import AboutTestimonial from '../../components/AboutTestimonial.astro';
import '../../styles/global.css';
---

<Layout title="About Us — Mimya" description="Learn about Mimya, our fragrance mission, research, team, and community." fullWidth={true}>
  <main class="about-page">
    <AboutHero />
    <AboutMission />
    <AboutInfo />
    <AboutTeam />
    <AboutTestimonial />
  </main>
</Layout>

<style>
  .about-page {
    overflow-x: hidden;
  }
</style>
