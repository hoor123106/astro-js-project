---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import AboutUs from '../components/AboutUs.astro';
import Database from '../components/Database.astro';
import Satisfaction from '../components/Satisfaction.astro';
import Features from '../components/Features.astro';
import FeaturedFragrances from '../components/FeaturedFragrances.astro';
import Mission from '../components/Mission.astro';
import Testimonials from '../components/Testimonials.astro';
import '../styles/global.css';

const title = "Luxury Fragrance - Your Ultimate Scent Guide";
const description = "Discover the world's largest database of perfumes, notes, and brands. Elegant, luxury fragrance guide.";
---

<Layout title={title} description={description} fullWidth={true}>
  <main class="home-main">
    <Hero />
    <AboutUs />
    <Database />
    <Satisfaction />
    <Features />
    <FeaturedFragrances />
    <Mission />
    <Testimonials />
  </main>
</Layout>

<style>
  .home-main {
    overflow-x: hidden;
  }
</style>
