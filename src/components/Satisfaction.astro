---
import '../styles/Satisfaction.css';
import { Image } from 'astro:assets';
import laughLogo from '../assets/images/laughLogo.png';
import calender from '../assets/images/calender.png';
import batch from '../assets/images/batch.png';
---

<section class="satisfaction">
  <div class="container satisfaction__container">
    <div class="satisfaction__item">
      <div class="satisfaction__icon">
       <Image src={laughLogo} alt="Laugh icon" loading="lazy" decoding="async" widths={[40, 56, 72]} sizes="56px" />
      </div>
      <div class="satisfaction__text">
        <h3>50,000+ Perfumes Listed</h3>
        <p>An ever-expanding collection, from iconic pillars to rare and discontinued gems.</p>
      </div>
    </div>
    
    <div class="satisfaction__item">
      <div class="satisfaction__icon">
         <Image src={calender} alt="Calendar icon" loading="lazy" decoding="async" widths={[40, 56, 72]} sizes="56px" />
      </div>
      <div class="satisfaction__text">
        <h3>3,000+ Verified Brands</h3>
        <p>Explore the complete olfactive portfolios of luxury houses, indie perfumers, and everything in between.</p>
      </div>
    </div>
    
    <div class="satisfaction__item">
      <div class="satisfaction__icon">
          <Image src={batch} alt="Batch icon" loading="lazy" decoding="async" widths={[40, 56, 72]} sizes="56px" />
      </div>
      <div class="satisfaction__text">
        <h3>1800+ Scent Notes Profiled</h3>
        <p>Journey through the building blocks of fragrance, from Bergamot to Ambergris.</p>
      </div>
    </div>
  </div>
</section>