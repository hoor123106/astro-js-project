---
import { Image } from 'astro:assets';
import p1 from '../assets/images/perfume1.png';
import p2 from '../assets/images/perfume2.png';
import p3 from '../assets/images/perfume3.png';
import p4 from '../assets/images/perfume4.png';
import p5 from '../assets/images/perfume-5.png';
import p6 from '../assets/images/perfume-6.png';
import '../styles/FeaturedFragrances.css';

const fragrances = [
  { img: p1, name: "Chanel No. 5 - The Icon", details: "Launched: 1921 | Family: Floral Aldehyde" },
  { img: p2, name: "Dior Sauvage - The Modern Classic", details: "Launched: 2015 | Family: Aromatic Fougere" },
  { img: p3, name: "Creed Aventus - The Powerhouse", details: "Launched: 2010 | Family: Chypre Fruity" },
  { img: p4, name: "Baccarat Rouge 540 - The Cult Favorite", details: "Launched: 2015 | Family: Amber Floral" },
  { img: p5, name: "Guerlain Shalimar - The Oriental Legend", details: "Launched: 1925 | Family: Amber Spicy" },
  { img: p6, name: "Le Labo Santal 33 - The Niche Star", details: "Launched: 2011 | Family: Woody Aromatic" },
];
---

<section class="fragrances">
  <div class="container">
    <div class="fragrances__header">
      <span class="fragrances__label">Featured Fragrances</span>
      <h2 class="fragrances__title">Discover Your Next Signature Scent</h2>
      <p class="fragrances__subtitle">
        Explore our curated selection of iconic, trending, and historically significant fragrances. Let your curiosity guide you.
      </p>
    </div>
    
    <div class="fragrances__grid">
      {fragrances.map((item) => (
        <button
          type="button"
          class="fragrance-card"
          data-full-image={item.img.src}
          data-title={item.name}
          aria-label={`Open ${item.name} image preview`}
        >
          <div class="fragrance-card__image-wrapper">
            <Image
              src={item.img}
              alt={item.name}
              class="fragrance-card__image"
              loading="lazy"
              decoding="async"
              widths={[160, 240, 320]}
              sizes="(max-width: 640px) 45vw, (max-width: 992px) 28vw, 220px"
            />
          </div>
          <div class="fragrance-card__info">
            <h3 class="fragrance-card__name">{item.name}</h3>
            <p class="fragrance-card__details">{item.details}</p>
          </div>
        </button>
      ))}
    </div>

    <div class="fragrances__actions">
      <a href="/perfume" class="btn btn-primary">Explore All Perfumes</a>
    </div>
  </div>

  <div class="fragrance-modal" id="fragrance-modal" aria-hidden="true">
    <button type="button" class="fragrance-modal__backdrop" data-close-modal aria-label="Close preview"></button>
    <div class="fragrance-modal__content" role="dialog" aria-modal="true" aria-label="Perfume image preview">
      <img id="fragrance-modal-image" class="fragrance-modal__image" alt="" />
    </div>
  </div>
</section>

<script>
  const modal = document.getElementById('fragrance-modal');
  const modalImage = document.getElementById('fragrance-modal-image');
  const cards = document.querySelectorAll('.fragrance-card');
  const closeTargets = document.querySelectorAll('[data-close-modal]');

  const openModal = (imageSrc, title) => {
    if (!modal || !modalImage) return;
    modalImage.src = imageSrc;
    modalImage.alt = title;
    modal.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  };

  const closeModal = () => {
    if (!modal || !modalImage) return;
    modal.setAttribute('aria-hidden', 'true');
    modalImage.src = '';
    document.body.style.overflow = '';
  };

  cards.forEach((card) => {
    card.addEventListener('click', () => {
      const imageSrc = card.getAttribute('data-full-image');
      const title = card.getAttribute('data-title') ?? 'Perfume preview';
      if (imageSrc) openModal(imageSrc, title);
    });
  });

  closeTargets.forEach((el) => el.addEventListener('click', closeModal));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && modal?.getAttribute('aria-hidden') === 'false') {
      closeModal();
    }
  });
</script>
