---
import { Image } from 'astro:assets';
import bookIcon from '../assets/images/book-icon.png';
import shieldIcon from '../assets/images/shield-icon.png';
import clockIcon from '../assets/images/clock-icon.png';
import '../styles/about-info.css';
---

<section class="about-info">
  <div class="container about-info__container">
    <div class="about-info__top">
      <div class="about-info__header">
        <p class="about-info__label">About Us</p>
        <h2 class="about-info__title">We Don’t Sell. We Inform.</h2>
      </div>
      <div class="about-info__summary">
        <p>
          Because we are not tied to a specific brand or sales quota, our reviews are unbiased. We don't write glowing reviews to move inventory. We write to inform your decision. If a fragrance has poor longevity or smells synthetic, we say it. If it’s a masterpiece, we explain why.
        </p>
      </div>
    </div>

    <div class="about-info__cards">
      <div class="about-info__card">
        <div class="about-info__icon">
          <Image src={bookIcon} alt="Encyclopedia icon" />
        </div>
        <h3>Your Encyclopedia Of Scent.</h3>
      </div>

      <div class="about-info__card">
        <div class="about-info__icon">
          <Image src={shieldIcon} alt="Honest reviews icon" />
        </div>
        <h3>Honest Reviews, No Sales Agenda.</h3>
      </div>

      <div class="about-info__card">
        <div class="about-info__icon">
          <Image src={clockIcon} alt="History and trends icon" />
        </div>
        <h3>History, Trends, And Artistry.</h3>
      </div>
    </div>
  </div>
</section>